{
    "name": "regionallyfamous/aldus",
    "description": "Aldus — Block Compositor. AI-powered layout generation for WordPress Gutenberg.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Regionally Famous",
            "homepage": "https://regionallyfamous.com"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Aldus\\": "src/php/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aldus\\Tests\\": "tests/phpunit/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
