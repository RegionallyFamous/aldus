{
	"name": "aldus",
	"version": "1.28.0",
	"description": "AI Block Compositor for WordPress",
	"scripts": {
		"build": "wp-scripts build --blocks-manifest && node bin/inject-build-hash.js",
		"start": "wp-scripts start",
		"lint": "npm run lint:js && npm run lint:css && npm run lint:php && npm run analyze:php",
		"lint:js": "wp-scripts lint-js src/",
		"lint:css": "wp-scripts lint-style",
		"lint:php": "composer run phpcs",
		"lint:php:syntax": "find . -name '*.php' -not -path './node_modules/*' -not -path './build/*' -not -path './vendor/*' -print0 | xargs -0 php -l",
		"analyze:php": "composer run phpstan",
		"fix": "npm run fix:js && npm run fix:css && npm run fix:php",
		"fix:js": "wp-scripts format src/",
		"fix:css": "wp-scripts lint-style --fix",
		"fix:php": "composer run phpcbf",
		"test": "npm run test:php:unit && npm run test:js",
		"test:js": "wp-scripts test-unit-js --config jest.config.js",
		"test:js:watch": "wp-scripts test-unit-js --config jest.config.js --watch",
		"test:php": "php tests/validate-blocks.php",
		"test:php:validate": "php tests/validate-blocks.php",
		"test:php:unit": "vendor/bin/phpunit --testsuite unit",
		"test:php:integration": "vendor/bin/phpunit -c phpunit-integration.xml.dist",
		"test:php:integration:dev": "WP_ENVIRONMENT_TYPE=development vendor/bin/phpunit -c phpunit-integration.xml.dist",
		"test:php:wxr": "vendor/bin/phpunit -c phpunit-integration.xml.dist --filter WxrImportedPostsValidationTest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"coverage:php": "vendor/bin/phpunit --testsuite unit --coverage-html coverage/php",
		"coverage:js": "wp-scripts test-unit-js --config jest.config.js --coverage",
		"ci": "npm run lint && npm run test && npm run build",
		"env:start": "wp-env start",
		"env:stop": "wp-env stop",
		"release": "node scripts/release.js",
		"release:patch": "node scripts/release.js --bump patch",
		"release:minor": "node scripts/release.js --bump minor",
		"release:major": "node scripts/release.js --bump major",
		"release:zip": "bash bin/release-zip.sh",
		"i18n:pot": "wp i18n make-pot . languages/aldus.pot --exclude=node_modules,build,vendor,tests",
		"i18n:json": "wp i18n make-json languages/aldus.pot languages/ --no-purge"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.1",
		"@playwright/test": "^1.58.2",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^18.3.28",
		"@wordpress/e2e-test-utils-playwright": "^1.43.0",
		"@wordpress/env": "^11.3.0",
		"@wordpress/icons": "^12.1.0",
		"@wordpress/scripts": "^31.8.0"
	},
	"dependencies": {
		"@mlc-ai/web-llm": "^0.2.82",
		"@wordpress/interactivity": "^6.43.0"
	},
	"peerDependencies": {
		"@wordpress/a11y": "*",
		"@wordpress/api-fetch": "*",
		"@wordpress/block-editor": "*",
		"@wordpress/blocks": "*",
		"@wordpress/components": "*",
		"@wordpress/compose": "*",
		"@wordpress/core-data": "*",
		"@wordpress/data": "*",
		"@wordpress/date": "*",
		"@wordpress/editor": "*",
		"@wordpress/element": "*",
		"@wordpress/hooks": "*",
		"@wordpress/i18n": "*",
		"@wordpress/keyboard-shortcuts": "*",
		"@wordpress/notices": "*",
		"@wordpress/plugins": "*",
		"@wordpress/preferences": "*"
	}
}
