{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "aldus/layout-generator",
	"version": "1.0.0",
	"title": "Aldus",
	"category": "text",
	"icon": "table-col-after",
	"description": "Your words, sixteen personalities. Drop in your content and Aldus tries it in up to sixteen layout styles — pick the one that fits.",
	"keywords": [ "layout", "personality", "aldus", "design", "arrange", "compositor" ],
	"textdomain": "aldus",
	"attributes": {
		"enabledPersonalities": {
			"type": "array",
			"items": { "type": "string" },
			"default": [ "Dispatch", "Folio", "Stratum", "Broadside", "Manifesto", "Nocturne", "Tribune", "Overture", "Codex", "Dusk", "Broadsheet", "Solstice", "Mirage", "Ledger", "Mosaic", "Prism" ]
		},
		"savedItems": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"id":      { "type": "string" },
					"type":    { "type": "string" },
					"content": { "type": "string" },
					"url":     { "type": "string" },
					"mediaId": { "type": "integer" },
					"urls":    { "type": "array", "items": { "type": "string" } }
				}
			},
			"default": []
		},
		"styleNote": {
			"type": "string",
			"default": ""
		}
	},
	"example": {
		"attributes": {
			"savedItems": [
				{ "id": "ex1", "type": "headline",  "content": "Espresso at Altitude", "url": "" },
				{ "id": "ex2", "type": "subheading","content": "A single-origin story", "url": "" },
				{ "id": "ex3", "type": "paragraph", "content": "Sourced from 2,400m farms in the Yirgacheffe region, these beans carry a brightness that no lower-altitude crop can match.", "url": "" },
				{ "id": "ex4", "type": "image",     "content": "", "url": "" },
				{ "id": "ex5", "type": "cta",       "content": "Explore the farm", "url": "#" }
			],
			"styleNote": ""
		}
	},
	"supports": {
		"html": false,
		"multiple": false,
		"reusable": false,
		"lock": false
	},
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css"
}
