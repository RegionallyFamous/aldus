includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 6

    paths:
        - aldus.php
        - includes/
        - uninstall.php

    bootstrapFiles:
        - vendor/autoload.php

    scanFiles:
        - vendor/php-stubs/wordpress-stubs/wordpress-stubs.php

    excludePaths:
        - build/
        - node_modules/
        - vendor/
        - tests/
        - src/

    # These are defensive-coding patterns and known WordPress extension points.

    treatPhpDocTypesAsCertain: false

    # Suppress deprecated parameter warnings that replace the old boolean flags.
    ignoreErrors:
        - message: '#on left side of \?\? always exists and is not nullable#'
        - message: '#aldus_pick_large_font expects#'
        - message: "#Offset 'mediaId' does not exist on array#"
        # String-form callbacks are valid in WordPress but PHPStan WP stubs flag them.
        - message: '#Parameter \#2 \$callback of function add_action expects callable\(\): mixed#'
        # ALDUS_URL is defined at global scope in aldus.php but PHPStan loses track of it
        # when scanning includes/ independently.
        - message: '#Constant ALDUS_URL not found#'
        - identifier: missingType.iterableValue
        # - identifier: missingType.generics  # uncomment if generic type errors appear
